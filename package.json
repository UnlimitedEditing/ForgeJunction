{
  "name": "forge-junction",
  "version": "0.4.0",
  "description": "Forge Junction — AI media studio powered by Graydient.ai",
  "author": "ForgeJunction",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:editor": "npx serve alt-editor/omniclip-main/x -p 3000",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-packager . \"Forge Junction\" --platform=win32 --arch=x64 --out=release --overwrite --asar --ignore=\"^/(src|electron|dev-journal|\\.env|\\.gitignore|tsconfig|tailwind|postcss|electron\\.vite\\.config|launch\\.bat|README|claude-code)\"",
    "build:omniclip": "cd alt-editor/omniclip-main && npm run build",
    "package:installer": "npm run build:omniclip && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder",
    "publish": "electron-builder --publish always"
  },
  "dependencies": {
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.3.0",
    "fluent-ffmpeg": "^2.1.3",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@electron/packager": "^19.0.5",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3",
    "electron-vite": "^2.3.0",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.5",
    "vite": "^5.2.12"
  },
  "build": {
    "appId": "com.forgejunction.app",
    "productName": "Forge Junction",
    "publish": {
      "provider": "github",
      "owner": "UnlimitedEditing",
      "repo": "ForgeJunction",
      "releaseType": "release"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**",
      "dist/**",
      "!dist/assets/*.map"
    ],
    "extraResources": [
      {
        "from": "alt-editor/omniclip-main/x",
        "to": "omniclip",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
